# ─────────────────────────────────────────────────────────────────────────────
# Custom CNN Architecture
# 4 convolutional blocks: 32 → 64 → 128 → 256 filters
# Each block: Conv2D → BatchNorm → ReLU → Conv2D → BatchNorm → ReLU → MaxPool → Dropout
# Classifier: GlobalAvgPool → Dense(256) → Dropout → Dense(1, sigmoid)
# ─────────────────────────────────────────────────────────────────────────────

def build_custom_cnn(input_shape=(224, 224, 3)):
    inputs = keras.Input(shape=input_shape, name='input')

    # Block 1 — 32 filters
    x = layers.Conv2D(32, (3,3), padding='same', name='b1_conv1')(inputs)
    x = layers.BatchNormalization()(x)
    x = layers.Activation('relu')(x)
    x = layers.Conv2D(32, (3,3), padding='same', name='b1_conv2')(x)
    x = layers.BatchNormalization()(x)
    x = layers.Activation('relu')(x)
    x = layers.MaxPooling2D(2, 2)(x)
    x = layers.Dropout(0.25)(x)

    # Block 2 — 64 filters
    x = layers.Conv2D(64, (3,3), padding='same', name='b2_conv1')(x)
    x = layers.BatchNormalization()(x)
    x = layers.Activation('relu')(x)
    x = layers.Conv2D(64, (3,3), padding='same', name='b2_conv2')(x)
    x = layers.BatchNormalization()(x)
    x = layers.Activation('relu')(x)
    x = layers.MaxPooling2D(2, 2)(x)
    x = layers.Dropout(0.25)(x)

    # Block 3 — 128 filters
    x = layers.Conv2D(128, (3,3), padding='same', name='b3_conv1')(x)
    x = layers.BatchNormalization()(x)
    x = layers.Activation('relu')(x)
    x = layers.Conv2D(128, (3,3), padding='same', name='b3_conv2')(x)
    x = layers.BatchNormalization()(x)
    x = layers.Activation('relu')(x)
    x = layers.MaxPooling2D(2, 2)(x)
    x = layers.Dropout(0.30)(x)

    # Block 4 — 256 filters
    x = layers.Conv2D(256, (3,3), padding='same', name='b4_conv1')(x)
    x = layers.BatchNormalization()(x)
    x = layers.Activation('relu')(x)
    x = layers.GlobalAveragePooling2D()(x)  # reduces spatial dims efficiently
    x = layers.Dropout(0.40)(x)

    # Classifier head
    x = layers.Dense(256, activation='relu',
                     kernel_regularizer=regularizers.l2(1e-4))(x)
    x = layers.Dropout(0.50)(x)
    outputs = layers.Dense(1, activation='sigmoid', name='output')(x)

    return Model(inputs, outputs, name='Custom_CNN')


cnn_model = build_custom_cnn()
cnn_model.compile(
    optimizer=keras.optimizers.Adam(learning_rate=1e-3),
    loss='binary_crossentropy',
    metrics=['accuracy',
             keras.metrics.AUC(name='auc'),
             keras.metrics.Precision(name='precision'),
             keras.metrics.Recall(name='recall')]
)
cnn_model.summary()





