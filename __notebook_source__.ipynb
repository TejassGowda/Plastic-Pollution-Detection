# ── Data Augmentation ─────────────────────────────────────────────────────────
# Applied ONLY to training data to prevent overfitting
train_datagen = ImageDataGenerator(
    rescale=1./255,           # normalize [0,255] → [0,1]
    rotation_range=25,        # random rotation ±25°
    width_shift_range=0.15,   # horizontal shift up to 15%
    height_shift_range=0.15,  # vertical shift up to 15%
    shear_range=0.10,         # shear transformation
    zoom_range=0.20,          # random zoom in/out
