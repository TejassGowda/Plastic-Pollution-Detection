    validation_data=val_gen,
    callbacks=cnn_callbacks,
    verbose=1
)
print('CNN training complete!')





# ── EfficientNetB0: pretrained on ImageNet ────────────────────────────────────
# Phase 1: Freeze entire base, train custom head (5 epochs)
# Phase 2: Unfreeze last 20 layers, fine-tune with very low LR

def build_efficientnet():
    base = EfficientNetB0(weights='imagenet', include_top=False,
                          input_shape=(224, 224, 3))
    base.trainable = False  # freeze for Phase 1

    inputs = keras.Input(shape=(224, 224, 3))
    x = base(inputs, training=False)
    x = layers.GlobalAveragePooling2D()(x)
    x = layers.BatchNormalization()(x)
    x = layers.Dense(256, activation='relu',
                     kernel_regularizer=regularizers.l2(1e-4))(x)
    x = layers.Dropout(0.40)(x)
    x = layers.Dense(64, activation='relu')(x)
    x = layers.Dropout(0.30)(x)
    outputs = layers.Dense(1, activation='sigmoid')(x)

    return Model(inputs, outputs, name='EfficientNetB0'), base

eff_model, eff_base = build_efficientnet()
eff_model.compile(
    optimizer=keras.optimizers.Adam(learning_rate=1e-3),
    loss='binary_crossentropy',
    metrics=['accuracy', keras.metrics.AUC(name='auc'),
             keras.metrics.Precision(name='precision'),
             keras.metrics.Recall(name='recall')]
)

eff_callbacks = [
    EarlyStopping(monitor='val_accuracy', patience=6,
                  restore_best_weights=True, verbose=1),
    ReduceLROnPlateau(monitor='val_loss', factor=0.3, patience=3,
                     min_lr=1e-8, verbose=1),
    ModelCheckpoint('/kaggle/working/eff_best.h5',
                   monitor='val_accuracy', save_best_only=True, verbose=0)
]

# Phase 1: Train head only
print('EfficientNet Phase 1: Training head...')
eff_h1 = eff_model.fit(train_gen, epochs=5, validation_data=val_gen,
                        callbacks=eff_callbacks, verbose=1)

# Phase 2: Unfreeze last 20 layers
eff_base.trainable = True
for layer in eff_base.layers[:-20]:
    layer.trainable = False

eff_model.compile(
    optimizer=keras.optimizers.Adam(learning_rate=1e-3),  # much lower LR for fine-tuning
    loss='binary_crossentropy',
    metrics=['accuracy', keras.metrics.AUC(name='auc'),
             keras.metrics.Precision(name='precision'),
             keras.metrics.Recall(name='recall')]
)

print('EfficientNet Phase 2: Fine-tuning last 20 layers...')
eff_h2 = eff_model.fit(train_gen, epochs=EPOCHS, validation_data=val_gen,
                        callbacks=eff_callbacks, verbose=1)
print('EfficientNet training complete!')

# Merge both phase histories for plotting
def merge_hist(h1, h2):
    return {k: h1.history[k] + h2.history[k] for k in h1.history}

eff_hist = merge_hist(eff_h1, eff_h2)





# ── MobileNetV2: lightweight depthwise-separable convolutions ─────────────────
# Good for comparison: fewer params, faster inference vs EfficientNet

def build_mobilenet():
    base = MobileNetV2(weights='imagenet', include_top=False,
                       input_shape=(224, 224, 3))
    base.trainable = False

    inputs = keras.Input(shape=(224, 224, 3))
    x = base(inputs, training=False)
    x = layers.GlobalAveragePooling2D()(x)
    x = layers.Dense(128, activation='relu')(x)
    x = layers.Dropout(0.35)(x)
    outputs = layers.Dense(1, activation='sigmoid')(x)

    return Model(inputs, outputs, name='MobileNetV2'), base

mob_model, mob_base = build_mobilenet()
mob_model.compile(
    optimizer=keras.optimizers.Adam(learning_rate=1e-3),
    loss='binary_crossentropy',
    metrics=['accuracy', keras.metrics.AUC(name='auc'),
             keras.metrics.Precision(name='precision'),
             keras.metrics.Recall(name='recall')]
)

mob_callbacks = [
    EarlyStopping(monitor='val_accuracy', patience=6,
                  restore_best_weights=True, verbose=1),
    ReduceLROnPlateau(monitor='val_loss', factor=0.3, patience=3,
                     min_lr=1e-8, verbose=1),
]

# Phase 1
print('MobileNetV2 Phase 1: Training head...')
mob_h1 = mob_model.fit(train_gen, epochs=5, validation_data=val_gen,
                        callbacks=mob_callbacks, verbose=1)

# Phase 2: Unfreeze last 30 layers
mob_base.trainable = True
for layer in mob_base.layers[:-30]:
    layer.trainable = False

mob_model.compile(
    optimizer=keras.optimizers.Adam(learning_rate=1e-3),
    loss='binary_crossentropy',
    metrics=['accuracy', keras.metrics.AUC(name='auc'),
             keras.metrics.Precision(name='precision'),
             keras.metrics.Recall(name='recall')]
)

print('MobileNetV2 Phase 2: Fine-tuning...')
mob_h2 = mob_model.fit(train_gen, epochs=EPOCHS, validation_data=val_gen,
                        callbacks=mob_callbacks, verbose=1)
mob_hist = merge_hist(mob_h1, mob_h2)
print('MobileNetV2 training complete!')





def plot_curves(hist_dict, model_name, save_path):
    acc      = hist_dict['accuracy']
    val_acc  = hist_dict['val_accuracy']
    loss     = hist_dict['loss']
    val_loss = hist_dict['val_loss']
    epochs   = range(1, len(acc) + 1)

    fig, axes = plt.subplots(1, 2, figsize=(13, 5))
    fig.suptitle(f'{model_name} — Training Curves', fontsize=13, fontweight='bold')

    axes[0].plot(epochs, acc,     'b-o', ms=4, label='Train')
    axes[0].plot(epochs, val_acc, 'r-s', ms=4, label='Validation')
    axes[0].set_title('Accuracy')
    axes[0].set_xlabel('Epoch')
    axes[0].set_ylabel('Accuracy')
    axes[0].legend()
    axes[0].grid(True, alpha=0.3)
    axes[0].set_ylim(0, 1.05)

    axes[1].plot(epochs, loss,     'b-o', ms=4, label='Train')
    axes[1].plot(epochs, val_loss, 'r-s', ms=4, label='Validation')
    axes[1].set_title('Loss (Binary Cross-Entropy)')
    axes[1].set_xlabel('Epoch')
    axes[1].set_ylabel('Loss')
    axes[1].legend()
    axes[1].grid(True, alpha=0.3)

    plt.tight_layout()
    plt.savefig(save_path, dpi=150, bbox_inches='tight')
    plt.show()
    print(f'Saved: {save_path}')

plot_curves(cnn_model.history.history, 'Custom CNN',
            f'{SAVE_DIR}/04_cnn_curves.png')
plot_curves(eff_hist, 'EfficientNetB0',
            f'{SAVE_DIR}/05_efficientnet_curves.png')
plot_curves(mob_hist, 'MobileNetV2',
            f'{SAVE_DIR}/06_mobilenet_curves.png')





def evaluate_model(model, generator, model_name, threshold=0.5):
    generator.reset()
    y_prob = model.predict(generator, verbose=0).flatten()
    y_pred = (y_prob >= threshold).astype(int)
    y_true = generator.classes

    print(f'\n{"="*55}')
    print(f'  {model_name}')
    print(f'{"="*55}')
    print(classification_report(y_true, y_pred, target_names=CLASS_NAMES))

    loss, acc, *_ = model.evaluate(generator, verbose=0)
    print(f'  Test Loss     : {loss:.4f}')
    print(f'  Test Accuracy : {acc:.4f}')

    return y_prob, y_pred, y_true

test_gen.reset()
cnn_prob, cnn_pred, y_true = evaluate_model(cnn_model, test_gen, 'Custom CNN')

test_gen.reset()
eff_prob, eff_pred, _      = evaluate_model(eff_model, test_gen, 'EfficientNetB0')

test_gen.reset()
mob_prob, mob_pred, _      = evaluate_model(mob_model, test_gen, 'MobileNetV2')


