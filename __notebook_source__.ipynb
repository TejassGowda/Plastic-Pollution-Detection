def get_gradcam(model, img_array, last_conv_name):
    """Compute Grad-CAM heatmap for a binary classifier."""
    grad_model = Model(
        inputs=model.inputs,
        outputs=[model.get_layer(last_conv_name).output, model.output]
    )
    with tf.GradientTape() as tape:
        conv_out, pred = grad_model(img_array)
        loss = pred[:, 0]
    grads       = tape.gradient(loss, conv_out)
    pooled_grad = tf.reduce_mean(grads, axis=(0, 1, 2))
    conv_out    = conv_out[0]
    heatmap     = conv_out @ pooled_grad[..., tf.newaxis]
    heatmap     = tf.squeeze(heatmap)
    heatmap     = tf.maximum(heatmap, 0)
    heatmap     = heatmap / (tf.math.reduce_max(heatmap) + 1e-8)
    return heatmap.numpy()

def overlay(img_path, heatmap, alpha=0.45):
    img = cv2.imread(img_path)
    img = cv2.resize(img, IMG_SIZE)
    img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)
    h   = cv2.resize(heatmap, IMG_SIZE)
    h   = np.uint8(255 * h)
    hc  = cv2.applyColorMap(h, cv2.COLORMAP_JET)
    hc  = cv2.cvtColor(hc, cv2.COLOR_BGR2RGB)
    sup = cv2.addWeighted(img, 1-alpha, hc, alpha, 0)
    return img, sup

# Find last conv layer in custom CNN
last_conv = [l.name for l in cnn_model.layers if isinstance(l, layers.Conv2D)][-1]
print(f'Last conv layer: {last_conv}')

# 3 plastic + 3 non-plastic samples
sample_paths  = (test_df[test_df['label'] == 'plastic']['path'].sample(3, random_state=5).tolist() +
                 test_df[test_df['label'] == 'non_plastic']['path'].sample(3, random_state=5).tolist())
sample_labels = ['plastic']*3 + ['non_plastic']*3

fig, axes = plt.subplots(6, 3, figsize=(12, 22))
fig.suptitle('Grad-CAM — What the CNN focuses on for plastic detection',
             fontsize=13, fontweight='bold')

for row, (path, true_lbl) in enumerate(zip(sample_paths, sample_labels)):
    pil   = tf.keras.preprocessing.image.load_img(path, target_size=IMG_SIZE)
    arr   = tf.keras.preprocessing.image.img_to_array(pil) / 255.0
    arr4d = np.expand_dims(arr, 0)

    prob   = cnn_model.predict(arr4d, verbose=0)[0][0]
    pred   = 'plastic' if prob >= 0.5 else 'non_plastic'
    mark   = 'CORRECT' if pred == true_lbl else 'WRONG'
    color  = 'green' if mark == 'CORRECT' else 'red'

    hm         = get_gradcam(cnn_model, arr4d, last_conv)
    orig, sup  = overlay(path, hm)

    axes[row,0].imshow(orig)
    axes[row,0].set_title(f'True: {true_lbl}', fontsize=9)
    axes[row,0].axis('off')

    axes[row,1].imshow(hm, cmap='jet')
    axes[row,1].set_title('Heatmap', fontsize=9)
    axes[row,1].axis('off')

    axes[row,2].imshow(sup)
    axes[row,2].set_title(f'Pred: {pred} ({prob:.2f}) [{mark}]',
                          fontsize=9, color=color)
    axes[row,2].axis('off')

plt.tight_layout()
